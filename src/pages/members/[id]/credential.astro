---
import BaseLayout from "@layouts/BaseLayout.astro";
import { QrCredential } from "@modules/qr/components/QrCredential";

const memberId = Astro.params.id!;
---

<BaseLayout title="Credencial">
  <main class="p-6">
    <div class="mx-auto max-w-lg">
      <a href={`/members/${memberId}`} class="mb-4 inline-block text-sm text-muted-foreground hover:text-primary">
        &larr; Volver a editar miembro
      </a>
      <QrCredential client:load memberId={memberId} />
    </div>
  </main>
</BaseLayout>
